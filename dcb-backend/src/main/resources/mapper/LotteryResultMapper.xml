<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.dcb.lottery.mapper.LotteryResultMapper">

    <resultMap id="BaseResultMap" type="com.dcb.lottery.entity.LotteryResult">
        <id     column="fid"         property="id"/>
        <result column="fissue"      property="issue"/>
        <result column="fdraw_date"  property="drawDate"/>
        <result column="fred1"       property="red1"/>
        <result column="fred2"       property="red2"/>
        <result column="fred3"       property="red3"/>
        <result column="fred4"       property="red4"/>
        <result column="fred5"       property="red5"/>
        <result column="fred6"       property="red6"/>
        <result column="fblue"       property="blue"/>
        <result column="fcreated_at" property="createdAt"/>
    </resultMap>

    <select id="selectPage" resultMap="BaseResultMap">
        SELECT fid, fissue, fdraw_date, fred1, fred2, fred3, fred4, fred5, fred6, fblue, fcreated_at
        FROM t_lottery_result
        <where>
            <if test="issue != null and issue != ''">
                AND fissue LIKE CONCAT('%', #{issue}, '%')
            </if>
            <if test="startDate != null">
                AND fdraw_date &gt;= #{startDate}
            </if>
            <if test="endDate != null">
                AND fdraw_date &lt;= #{endDate}
            </if>
        </where>
        ORDER BY fissue DESC
    </select>

</mapper>
