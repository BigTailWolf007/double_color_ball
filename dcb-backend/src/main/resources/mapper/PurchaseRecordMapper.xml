<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.dcb.purchase.mapper.PurchaseRecordMapper">

    <resultMap id="BaseResultMap" type="com.dcb.purchase.entity.PurchaseRecord">
        <id     column="fid"          property="id"/>
        <result column="fissue"       property="issue"/>
        <result column="fred1"        property="red1"/>
        <result column="fred2"        property="red2"/>
        <result column="fred3"        property="red3"/>
        <result column="fred4"        property="red4"/>
        <result column="fred5"        property="red5"/>
        <result column="fred6"        property="red6"/>
        <result column="fblue"        property="blue"/>
        <result column="fball_key"    property="ballKey"/>
        <result column="fquantity"    property="quantity"/>
        <result column="fprize_level" property="prizeLevel"/>
        <result column="fprize_money" property="prizeMoney"/>
        <result column="fremark"      property="remark"/>
        <result column="fcreated_at"  property="createdAt"/>
        <result column="fsum_val"        property="sumVal"/>
        <result column="fzone_ratio"     property="zoneRatio"/>
        <result column="fodd_even_ratio" property="oddEvenRatio"/>
        <result column="frange_val"      property="rangeVal"/>
        <result column="fuser_id"       property="userId"/>
    </resultMap>

    <select id="selectPageByCondition" resultMap="BaseResultMap">
        SELECT fid, fissue, fred1, fred2, fred3, fred4, fred5, fred6, fblue, fball_key,
               fquantity, fprize_level, fprize_money, fremark, fcreated_at,
               fsum_val, fzone_ratio, fodd_even_ratio, frange_val, fuser_id
        FROM t_purchase_record
        <where>
            <if test="userId != null">
                AND (fuser_id = #{userId} OR fuser_id IS NULL)
            </if>
            <if test="issue != null and issue != ''">
                AND fissue LIKE CONCAT('%', #{issue}, '%')
            </if>
            <if test="prizeLevels != null and prizeLevels.size() > 0 or includeNullPrize">
                AND (
                    <if test="prizeLevels != null and prizeLevels.size() > 0">
                        fprize_level IN
                        <foreach collection="prizeLevels" item="lv" open="(" separator="," close=")">
                            #{lv}
                        </foreach>
                        <if test="includeNullPrize"> OR </if>
                    </if>
                    <if test="includeNullPrize">
                        fprize_level IS NULL
                    </if>
                )
            </if>
        </where>
        ORDER BY fissue DESC, fcreated_at DESC
    </select>

    <select id="selectBallKeysByIssue" resultType="string">
        SELECT fball_key FROM t_purchase_record WHERE fissue = #{issue}
    </select>

    <select id="selectIssuesByKeyword" resultType="string">
        SELECT DISTINCT fissue FROM t_purchase_record
        WHERE fissue LIKE CONCAT('%', #{keyword}, '%')
        ORDER BY fissue DESC
        LIMIT #{limit}
    </select>

    <select id="selectSummary" resultType="java.util.Map">
        SELECT
            COALESCE(SUM(fquantity), 0)    AS totalQuantity,
            COALESCE(SUM(fprize_money), 0) AS totalPrizeMoney
        FROM t_purchase_record
        <where>
            <if test="userId != null">
                AND (fuser_id = #{userId} OR fuser_id IS NULL)
            </if>
            <if test="issue != null and issue != ''">
                AND fissue LIKE CONCAT('%', #{issue}, '%')
            </if>
            <if test="prizeLevels != null and prizeLevels.size() > 0 or includeNullPrize">
                AND (
                    <if test="prizeLevels != null and prizeLevels.size() > 0">
                        fprize_level IN
                        <foreach collection="prizeLevels" item="lv" open="(" separator="," close=")">
                            #{lv}
                        </foreach>
                        <if test="includeNullPrize"> OR </if>
                    </if>
                    <if test="includeNullPrize">
                        fprize_level IS NULL
                    </if>
                )
            </if>
        </where>
    </select>
    <update id="batchUpdatePrize" parameterType="java.util.List">
        <foreach collection="list" item="r" separator=";">
            UPDATE t_purchase_record
            SET fprize_level = #{r.prizeLevel},
                fprize_money = #{r.prizeMoney}
            WHERE fid = #{r.id}
        </foreach>
    </update>

</mapper>
