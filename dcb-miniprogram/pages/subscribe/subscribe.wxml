<!-- 订阅付费页 -->
<view class="container">
  <view class="subscribe-header">
    <text style="font-size:36rpx;font-weight:700;">升级订阅</text>
    <text style="font-size:26rpx;color:#909399;margin-top:8rpx;">解锁双色球分析全部功能</text>
  </view>

  <!-- 套餐卡片 -->
  <view class="plans">
    <view wx:for="{{plans}}" wx:key="id" class="plan-card {{selectedPlan === item.id ? 'active' : ''}}" bindtap="selectPlan" data-id="{{item.id}}">
      <view class="plan-name">{{item.name}}</view>
      <view class="plan-price">
        <text style="font-size:28rpx;">¥</text>
        <text style="font-size:60rpx;font-weight:700;">{{item.price}}</text>
      </view>
      <view class="plan-original" wx:if="{{item.originalPrice}}">原价 ¥{{item.originalPrice}}</view>
      <view class="plan-desc">{{item.desc}}</view>
    </view>
  </view>

  <!-- 权益说明 -->
  <view class="card" style="margin-top:20rpx;">
    <view class="card-title">订阅权益</view>
    <view wx:for="{{benefits}}" wx:key="index" class="benefit-item">✓ {{item}}</view>
  </view>

  <!-- 支付按钮 -->
  <button class="btn btn-primary btn-block pay-btn" bindtap="handlePay" disabled="{{!selectedPlan}}">
    {{selectedPlan ? '立即订阅 ¥' + selectedPlanPrice : '请选择套餐'}}
  </button>
</view>
