.subscribe-header {
  text-align: center;
  padding: 40rpx 0;
}

.plans {
  display: flex;
  gap: 16rpx;
}

.plan-card {
  flex: 1;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  text-align: center;
  border: 2rpx solid #e0e0e0;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.plan-card.active {
  border-color: #d43030;
  background: #fef8f8;
}

.plan-name {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.plan-price {
  color: #d43030;
  margin-bottom: 4rpx;
}

.plan-original {
  font-size: 22rpx;
  color: #ccc;
  text-decoration: line-through;
  margin-bottom: 8rpx;
}

.plan-desc {
  font-size: 22rpx;
  color: #909399;
}

.benefit-item {
  padding: 12rpx 0;
  font-size: 26rpx;
  color: #606266;
  border-bottom: 1rpx solid #f5f5f5;
}

.benefit-item:last-child {
  border-bottom: none;
}

.pay-btn {
  position: fixed;
  bottom: 40rpx;
  left: 40rpx;
  right: 40rpx;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
}
