.user-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #f0f0f0;
}

.user-name {
  font-size: 32rpx;
  font-weight: 600;
}

.user-role {
  font-size: 24rpx;
  color: #909399;
  margin-top: 4rpx;
}

.subscribe-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  font-size: 28rpx;
}

.menu-item:last-child {
  border-bottom: none;
}
