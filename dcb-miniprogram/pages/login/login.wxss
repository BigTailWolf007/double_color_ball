.login-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  padding: 0 60rpx;
  background: linear-gradient(135deg, #d43030 0%, #e85d5d 100%);
}

.login-logo {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.login-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 16rpx;
}

.login-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 80rpx;
}

.login-btn {
  width: 100%;
  height: 88rpx;
  background: #fff;
  color: #d43030;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.login-tip {
  margin-top: 40rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}
