.lottery-result {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.issue-tag {
  background: #fef0f0;
  color: #d43030;
  padding: 6rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.stat-cards {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.stat-card {
  flex: 1;
  text-align: center;
}

.recommend-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.recommend-item:last-child {
  border-bottom: none;
}
